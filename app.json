{
  "expo": {
    "name": "Aether",
    "slug": "aether",
    "owner": "atikmahbub100",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aether",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0f13",

    "splash": {
      "backgroundColor": "#0a0f13",
      "resizeMode": "contain",
      "image": "./assets/splash.png"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atik.aether",
      "infoPlist": {
        "CFBundleDisplayName": "Aether",
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "UIViewControllerBasedStatusBarAppearance": false,
        "NSFaceIDUsageDescription": "Use Face ID to securely unlock your wallet."
      }
    },

    "android": {
      "package": "com.atik.aether",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0f13"
      }
    },

    "web": {
      "output": "static",
      "favicon": "./assets/icon.png"
    },

    "plugins": ["expo-router", "expo-secure-store", "expo-font"],

    "extra": {
      "auth0Domain": "dev-pm0712stgt281lme.us.auth0.com",
      "auth0ClientId": "ZKFTcNI7NKpHeAv11HY5qQjCIpkddOH9",
      "auth0Audience": "https://api.tracking-wallet.com",
      "router": {},
      "eas": {
        "projectId": "f6321d98-7753-456b-b4c8-61857344a854"
      }
    },

    "experiments": {
      "typedRoutes": true,
      "newArchEnabled": false
    }
  }
}